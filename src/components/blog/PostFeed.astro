---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<div class="feed-wrapper">
  {posts.map((post) => <PostCard post={post} />)}
</div>

<style>
  .feed-wrapper {
    width: 100%;
    max-width: 470px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
  }
</style>
