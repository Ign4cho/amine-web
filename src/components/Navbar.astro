---
const navItems = [
  { label: "HOME",         href: "/",         key: "home"        },
  { label: "BLOGCITO",     href: "/blogcito",  key: "blogcito"    },
  { label: "ALIADOS",      href: "/aliados",   key: "aliados"     },
  { label: "CONTACTANOS!", href: "/contactanos", key: "contactanos" },
];
---

<nav
  x-data="{ active: window.location.pathname === '/' ? 'home' : window.location.pathname.replace('/', '') }"
  class="navbar-root"
>
  {navItems.map((item) => (
    <a
      href={item.href}
      class="nav-tab"
      :class={`active === '${item.key}' ? 'tab-active' : 'tab-inactive'`}
      @click={`active = '${item.key}'`}
    >
      {item.label}
    </a>
  ))}
</nav>

<style>
  .navbar-root {
    background-color: #2D2A29;
    width: 100%;
    display: flex;
    align-items: flex-end;
    height: 56px;
    padding: 0 14px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-sizing: border-box;
  }

  .nav-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-left: 20px;
    position: relative;
    height: 46px;
    margin: 0 14px;
    border-radius: 18px 18px 0 0;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.07em;
    text-decoration: none !important;
    text-decoration-line: none !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    color: #2D2A29;
    background-color: #F0C14B;
    transition: background-color 0.15s ease;
    cursor: pointer;
    white-space: nowrap;
  }

  .nav-tab::before,
  .nav-tab::after {
    content: "";
    position: absolute;
    bottom: 0;
    width: 12px;
    height: 12px;
    pointer-events: none;
  }

  .nav-tab::before {
    left: -12px;
    background-image: radial-gradient(circle at 0 0, transparent 11.5px, var(--tab-bg, #F0C14B) 12px);
  }

  .nav-tab::after {
    right: -12px;
    background-image: radial-gradient(circle at 100% 0, transparent 11.5px, var(--tab-bg, #F0C14B) 12px);
  }

  .tab-active {
    --tab-bg: #F9F4EA;
    background-color: var(--tab-bg) !important;
    color: #2D2A29 !important;
  }

  .tab-inactive {
    --tab-bg: #F0C14B;
    background-color: var(--tab-bg) !important;
    color: #2D2A29 !important;
  }

  @media (max-width: 768px) {
    .navbar-root {
        padding: 0 6px;
    }
    .nav-tab {
      font-size: 1rem;
      margin: 0 6px;
      padding: 0 16px;
      letter-spacing: 0.03em;
      border-radius: 12px 12px 0 0;
    }
    .nav-tab::before,
    .nav-tab::after {
      width: 6px;
      height: 6px;
    }
    .nav-tab::before {
      left: -6px;
      background-image: radial-gradient(circle at 0 0, transparent 5.5px, var(--tab-bg, #F0C14B) 6px);
    }
    .nav-tab::after {
      right: -6px;
      background-image: radial-gradient(circle at 100% 0, transparent 5.5px, var(--tab-bg, #F0C14B) 6px);
    }
  }
</style>
