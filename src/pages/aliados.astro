---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { WHATSAPP_URL } from '../constants';

const aliados = await getCollection('aliados');
const sorted = aliados.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Aliados — Amine Social Media">
  <Navbar />

  <main class="aliados-main">
    <header class="aliados-header">
      <h1 class="aliados-title">Aliados</h1>
      <p class="aliados-subtitle">
        Profesionales de confianza con quienes trabajamos para potenciar tu marca.
      </p>
    </header>

    <section class="aliados-grid-section">
      <div class="aliados-grid">
        {sorted.map((aliado) => (
          <article class="aliado-card">
            <div class="aliado-avatar-wrap">
              <Image
                src={aliado.data.avatar}
                alt={aliado.data.name}
                width={100}
                height={100}
                class="aliado-avatar"
              />
            </div>

            <h2 class="aliado-name">{aliado.data.name}</h2>
            <p class="aliado-description">{aliado.data.description}</p>

            <ul class="aliado-services">
              {aliado.data.services.map((service) => (
                <li class="service-tag">{service}</li>
              ))}
            </ul>

            <div class="aliado-contact">
              {aliado.data.contact.type === 'whatsapp' ? (
                <a
                  href={`https://wa.me/${aliado.data.contact.value}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="contact-btn contact-btn--whatsapp"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.117 1.532 5.845L.057 23.492a.5.5 0 0 0 .614.644l5.77-1.508A11.943 11.943 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.65-.523-5.158-1.433l-.36-.215-3.726.974.999-3.629-.236-.374A9.945 9.945 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
                  </svg>
                  WhatsApp
                </a>
              ) : (
                <a
                  href={`mailto:${aliado.data.contact.value}`}
                  class="contact-btn contact-btn--email"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="2" y="4" width="20" height="16" rx="2"/>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                  Email
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="aliados-cta">
      <p class="cta-text">¿Querés sumarte a nuestra red de aliados?</p>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="cta-btn"
      >
        Escribinos por WhatsApp
      </a>
    </section>
  </main>
</Layout>

<style>
  .aliados-main {
    min-height: 100vh;
    background-color: #F9F4EA;
  }

  .aliados-header {
    background-color: #2D2A29;
    padding: 3rem 1rem 2.5rem;
    text-align: center;
  }

  .aliados-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 5rem);
    color: #F0C14B;
    letter-spacing: 0.06em;
    margin: 0 0 0.5rem;
  }

  .aliados-subtitle {
    font-family: 'Open Sans', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    color: #F9F4EA;
    opacity: 0.8;
    margin: 0;
  }

  .aliados-grid-section {
    padding: 3rem 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .aliados-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .aliados-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .aliados-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .aliado-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 2rem 1.5rem;
    box-shadow: 0 2px 12px rgba(45, 42, 41, 0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }

  .aliado-avatar-wrap {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    border: 3px solid #F0C14B;
    overflow: hidden;
    flex-shrink: 0;
  }

  .aliado-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .aliado-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    color: #2D2A29;
    letter-spacing: 0.04em;
    margin: 0.25rem 0 0;
  }

  .aliado-description {
    font-family: 'Open Sans', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: #5C5753;
    line-height: 1.6;
    margin: 0;
  }

  .aliado-services {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
  }

  .service-tag {
    background: #F9F4EA;
    border: 1px solid #F0C14B;
    color: #2D2A29;
    font-family: 'Open Sans', sans-serif;
    font-weight: 300;
    font-size: 0.75rem;
    border-radius: 20px;
    padding: 0.2rem 0.65rem;
  }

  .aliado-contact {
    margin-top: 0.5rem;
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.06em;
    text-decoration: none;
    border-radius: 8px;
    padding: 0.5rem 1.2rem;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .contact-btn--whatsapp {
    background: #F0C14B;
    color: #2D2A29;
  }

  .contact-btn--whatsapp:hover {
    background: #2D2A29;
    color: #F0C14B;
  }

  .contact-btn--email {
    background: #2D2A29;
    color: #F9F4EA;
  }

  .contact-btn--email:hover {
    background: #F0C14B;
    color: #2D2A29;
  }

  .aliados-cta {
    background: #2D2A29;
    padding: 3rem 1rem;
    text-align: center;
  }

  .cta-text {
    font-family: 'Open Sans', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    color: #F9F4EA;
    margin: 0 0 1.25rem;
  }

  .cta-btn {
    display: inline-block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.3rem;
    letter-spacing: 0.06em;
    color: #2D2A29;
    background: #F0C14B;
    border-radius: 10px;
    padding: 0.7rem 2rem;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .cta-btn:hover {
    background: #F9F4EA;
  }
</style>
